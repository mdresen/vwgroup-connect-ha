meta {
  name: GET driving-data CYCLIC
  type: http
  seq: 49
}

get {
  url: {{base_url}}/v1/vehicles/{{vin}}/driving-data/CYCLIC?from=1970-01-01T00:00:00Z&to=2099-12-31T09:59:01Z
  body: none
  auth: bearer
}

auth:bearer {
  token: {{access_token}}
}

headers {
  Accept: application/json
}

docs {
  v2.11.2 — per-tank / per-charge refuel statistics for SEAT/CUPRA
  on the OLA backend. Replaces /v1/vehicles/{vin}/trips/lastrefuel
  (404 on PHEV firmwares as of #392 heidle78 diag).

  Response shape:
    {
      "data": [
        {
          "mileage_km" | "mileage": 612,
          "travelTime" | "traveltime": 480,
          "averageSpeed_kmph" | "averageSpeed": 76,
          "averageFuelConsumption": 5.8,
          "averageElectricEngineConsumption": 17.2,
          "totalFuelConsumption_l" | "totalFuelConsumption": 35.5,
          "totalElectricConsumption_kwh" | "totalElectricConsumption": 10.1,
          "tripEndTimestamp" | "timestamp": "..."
        },
        ...
      ]
    }

  Populates refuel_trip_* fields from entries[0] (most recent refuel
  / charge event).
}
