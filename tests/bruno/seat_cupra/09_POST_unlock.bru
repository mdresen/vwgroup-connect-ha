meta {
  name: POST vehicle unlock (S-PIN protected)
  type: http
  seq: 9
}

post {
  url: {{base_url}}/v1/vehicles/{{vin}}/access/unlock
  body: none
  auth: bearer
}

auth:bearer {
  token: {{access_token}}
}

headers {
  Accept: application/json
  SecToken: {{sec_token}}
}

docs {
  Unlock the vehicle remotely. Empty body — only the SecToken header.

  SecToken REQUIRED — derived from S-PIN via
  POST /v2/users/{userId}/spin/verify (see 12_POST_spin_verify.bru).

  Implementation: cariad/api/seat_cupra.py:command_unlock (line ~641).
}
