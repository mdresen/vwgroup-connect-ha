meta {
  name: POST climatisation timers (departure-timer write)
  type: http
  seq: 13
}

post {
  url: {{base_url}}/vehicle/v1/vehicles/{{vin}}/climatisation/timers
  body: json
  auth: bearer
}

auth:bearer {
  token: {{access_token}}
}

headers {
  Content-Type: application/json
  Accept: application/json
}

body:json {
  {
    "departureTimers": [
      {
        "id": 1,
        "enabled": true,
        "departureTimer": {
          "departureTime": "07:30",
          "recurringTimer": {
            "departureTimePattern": [
              "MONDAY", "TUESDAY", "WEDNESDAY", "THURSDAY", "FRIDAY"
            ]
          }
        }
      }
    ]
  }
}

docs {
  v1.16.0 (#26 closer) — set departure timer.

  Used by VWEUClient.command_set_departure_timer + the v1.16.0 HA
  ``time`` platform (time.{auto}_departure_timer_X_time_set entity).
  Also reachable via service vag_connect.set_departure_timer.

  Body shape: list of departure-timer objects with id, enabled, time,
  and recurring/one-off pattern. Empty list disables all timers.
  Note actual body shape may vary by Cariad firmware — this is the
  canonical shape from audi_connect_ha PR #644 era.

  Implementation: cariad/api/vw_eu.py:command_set_departure_timer.
}
