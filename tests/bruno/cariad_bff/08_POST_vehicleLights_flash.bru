meta {
  name: POST vehicleLights flash
  type: http
  seq: 8
}

post {
  url: {{base_url}}/vehicle/v1/vehicles/{{vin}}/vehicleLights/flash
  body: json
  auth: bearer
}

auth:bearer {
  token: {{access_token}}
}

headers {
  Content-Type: application/json
  Accept: application/json
}

body:json {
  {
    "action": "flash"
  }
}

docs {
  CARIAD-BFF flash for VW EU + Audi. No userPosition needed
  (unlike SEAT/CUPRA OLA where it's mandatory).

  Implementation: VWEUClient.command_flash() in cariad/api/vw_eu.py:309.
  Audi inherits.
}
