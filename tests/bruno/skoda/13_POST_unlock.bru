meta {
  name: POST unlock vehicle (S-PIN)
  type: http
  seq: 13
}

post {
  url: {{base_url}}/api/v1/vehicle-access/{{vin}}/unlock
  body: json
  auth: bearer
}

auth:bearer {
  token: {{access_token}}
}

headers {
  Accept: application/json
  Content-Type: application/json
}

body:json {
  {
    "spin": "1234"
  }
}

docs {
  Unlocks all doors. Skoda mysmob requires the user's 4-digit S-PIN
  in the JSON body (NOT a SecToken header like SEAT/CUPRA OLA).
  If no S-PIN is configured, the integration sends an empty body
  and the backend returns 400 — by design, we surface the auth
  error to the user.

  Implementation: SkodaClient.command_unlock() in
  custom_components/vag_connect/cariad/api/skoda.py:435.

  Backs the lock entity (unlock action). Replace "1234" with the
  real S-PIN before running this Bruno request.
}
